rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net - default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper to validate devis creation data
    function isValidDevis(data) {
      return data.clientName is string && data.clientName.size() <= 128
        && data.phone is string && data.phone.size() <= 64
        && data.city is string && data.city.size() <= 128
        && data.serviceType is string && data.serviceType.size() <= 128
        && data.urgency is string && data.urgency.size() <= 32;
    }

    match /devis/{devisId} {
      allow create: if isValidId(devisId) && isValidDevis(request.resource.data);
      allow read, update, delete: if isSignedIn();
    }

    // Helper to validate task data
    function isValidTask(data) {
      return data.title is string && data.title.size() <= 256
        && data.status is string && data.status.size() <= 32
        && data.userId is string && data.userId.size() <= 128;
    }

    match /tasks/{taskId} {
      allow create: if isSignedIn() && isValidId(taskId) && isValidTask(request.resource.data);
      allow read, update, delete: if isSignedIn();
    }
  }
}
